#DictionaryButton:hover {
    rotate: 2deg;
    border-top-width: 7px;
    border-right-width: 7px;
    border-bottom-width: 7px;
    border-left-width: 7px;
    border-top-right-radius: 17px;
    border-left-color: rgb(255, 255, 255);
    border-right-color: rgb(255, 255, 255);
    border-top-color: rgb(255, 255, 255);
    border-bottom-color: rgb(255, 255, 255);
    transition-duration: 0.3s, 0.2s;
    transition-property: all, rotate;
}

#SettingsButton:hover {
    border-top-width: 7px;
    border-right-width: 7px;
    border-bottom-width: 7px;
    border-left-width: 7px;
    border-left-color: rgb(255, 255, 255);
    border-right-color: rgb(255, 255, 255);
    border-top-color: rgb(255, 255, 255);
    border-bottom-color: rgb(255, 255, 255);
    border-top-left-radius: 17px;
    transition-duration: 0.3s, 0.2s;
    rotate: -2deg;
    transition-property: all, rotate;
}

#DictionaryButton:active {
    rotate: 2deg;
    width: 100px;
    height: 100px;
    transition-property: width, height;
    transition-duration: 0.1s, 0.1s;
}

#SettingsButton:active {
    rotate: -2deg;
    width: 100px;
    height: 100px;
    transition-property: width, height;
    transition-duration: 0.1s, 0.1s;
}

#DictionaryContainer > #BackButton:hover {
    scale: 1.1 1.1;
    -unity-background-image-tint-color: rgb(165, 0, 0);
    transition-duration: 0.1s;
}

.ConlangText {
     -unity-font-definition: url('/Assets/Resources/Fonts%20&%20Materials/Melody SDF.asset');
}

.EnglishText {
     -unity-font-definition: url('/Assets/Resources/Fonts%20&%20Materials/Harmony SDF.asset');
}