                <engine:VisualElement name="DictionarySlot2" style="flex-grow: 1; height: 100%; flex-direction: row; width: 100%; background-image: none; -unity-text-align: middle-left; justify-content: center; align-items: center; display: flex;">
                    <engine:Label text="Word" name="Word2" class="hotkey-text TranslatedLabel" style="-unity-text-align: lower-center; height: 40%; width: 50%; font-size: 40px; padding-bottom: 1%; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Melody.otf?fileID=12800000&amp;guid=ef39abd9056a9d446b1bf89b37383641&amp;type=3#Melody&quot;);" />
                    <engine:TextField placeholder-text="Notes..." name="Notes2" class="headers" style="width: 50%; font-size: 40px; height: 50%; padding-right: 10%; -unity-font-style: normal;" />
                </engine:VisualElement>
                <engine:VisualElement name="DictionarySlot3" style="flex-grow: 1; height: 100%; flex-direction: row; width: 100%; background-image: none; -unity-text-align: middle-left; justify-content: center; align-items: center; display: flex;">
                    <engine:Label text="Word" name="Word3" class="hotkey-text TranslatedLabel" style="-unity-text-align: lower-center; height: 40%; width: 50%; font-size: 40px; padding-bottom: 1%; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Melody.otf?fileID=12800000&amp;guid=ef39abd9056a9d446b1bf89b37383641&amp;type=3#Melody&quot;);" />
