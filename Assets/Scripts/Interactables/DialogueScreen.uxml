                </engine:VisualElement>
                <engine:VisualElement name="DictionarySlot4" style="flex-grow: 1; height: 100%; flex-direction: row; width: 100%; background-image: none; -unity-text-align: middle-left; justify-content: center; align-items: center; display: flex;">
                    <engine:Label text="Word" name="Word4" class="hotkey-text TranslatedLabel" style="-unity-text-align: lower-center; height: 40%; width: 50%; font-size: 40px; padding-bottom: 1%; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Melody.otf?fileID=12800000&amp;guid=ef39abd9056a9d446b1bf89b37383641&amp;type=3#Melody&quot;);" />
                    <engine:TextField placeholder-text="Notes..." name="Notes4" class="headers" style="width: 50%; font-size: 40px; height: 50%; padding-right: 10%; -unity-font-style: normal;" />
                </engine:VisualElement>
                <engine:VisualElement name="DictionarySlot5" style="flex-grow: 1; height: 100%; flex-direction: row; width: 100%; background-image: none; -unity-text-align: middle-left; justify-content: center; align-items: center; display: flex;">
                    <engine:Label text="Word" name="Word5" class="hotkey-text TranslatedLabel" style="-unity-text-align: lower-center; height: 40%; width: 50%; font-size: 40px; padding-bottom: 1%; -unity-font-style: bold; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Melody.otf?fileID=12800000&amp;guid=ef39abd9056a9d446b1bf89b37383641&amp;type=3#Melody&quot;);" />
                    <engine:TextField placeholder-text="Notes..." name="Notes5" class="headers" style="width: 50%; font-size: 40px; height: 50%; padding-right: 10%; -unity-font-style: normal;" />
                </engine:VisualElement>
                <engine:VisualElement name="Journal" style="flex-grow: 0; height: 500%; flex-direction: row; align-content: center; justify-content: center; display: none;">
                    <engine:TextField emoji-fallback-support="true" vertical-scroller-visibility="Auto" multiline="true" hide-placeholder-on-focus="false" name="JournalPage" style="flex-grow: 0; width: 80%; align-content: flex-start; align-self: center; justify-content: flex-start; height: 90%; background-color: rgba(255, 255, 255, 0); -unity-text-align: upper-left; white-space: pre-wrap; font-size: 40px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Harmony.otf?fileID=12800000&amp;guid=e0afdb4613b19e941a9c5e69c3b88d0f&amp;type=3#Harmony&quot;); color: rgb(27, 27, 27); display: flex;" />
                </engine:VisualElement>
                <engine:VisualElement name="NotebookBottom" style="flex-grow: 1; background-size: 100% 100%; background-color: rgb(255, 224, 152); height: 70%; width: 100%; flex-direction: row; align-content: center; justify-content: center; border-top-left-radius: 35px; border-top-right-radius: 35px; border-bottom-right-radius: 35px; border-bottom-left-radius: 35px;">
                    <engine:Button name="BackPage" class="button" style="width: 6%; height: 100%; background-image: url(&quot;project://database/Assets/UI/Images/Game%20HUD/UMBackButton.png?fileID=2800000&amp;guid=f56e3ad6aff3b5f49b6c280af4acf703&amp;type=3#UMBackButton&quot;); background-size: 100% 100%; background-color: rgb(255, 252, 244); align-self: auto; margin-left: 4px; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0; margin-right: 20%;" />
                    <engine:Label text="0/0" name="PageCount" emoji-fallback-support="false" class="headers" style="-unity-text-align: upper-center; font-size: 40px;" />
                    <engine:Button name="ForwardPage" class="button" style="width: 6%; height: 100%; background-image: url(&quot;project://database/Assets/UI/Images/Game%20HUD/UMForwardButton.png?fileID=2800000&amp;guid=79803b126e90f754a9ec24fbdd663497&amp;type=3#UMForwardButton&quot;); background-size: 100% 100%; background-color: rgb(255, 252, 244); align-self: auto; margin-left: 20%; border-left-color: rgb(255, 252, 244); border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;" />
                </engine:VisualElement>
            </engine:VisualElement>
        </engine:VisualElement>
        <engine:Label text="NPC NAME" name="NpcName" class="nametag" />
        <engine:VisualElement name="DialogueBox" class="dialogue-box" style="flex-grow: 0;">
            <engine:VisualElement name="NpcImage" class="dialogue-image" />
            <engine:VisualElement name="TextContainer" style="flex-grow: 1; align-items: center; align-self: center; flex-direction: row; justify-content: center; flex-wrap: wrap; align-content: flex-start; margin-left: 20px; padding-left: 0;" />
            <engine:VisualElement name="NextLinePrompt" class="prompt" />
        </engine:VisualElement>
        <engine:Button name="NotebookButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" class="hud-button" style="background-image: url(&quot;project://database/Assets/UI/Images/Game%20HUD/UMDictionaryButtonNormal.png?fileID=2800000&amp;guid=7d5ad70ac0adf9245a0a72a9314e13e0&amp;type=3#UMDictionaryButtonNormal&quot;); border-top-right-radius: 17px; position: absolute; top: auto; left: 0; bottom: 0;" />
    </engine:VisualElement>
    <engine:VisualElement name="WordTooltip" style="flex-grow: 1; position: absolute; display: none; background-color: rgb(245, 215, 157); border-top-left-radius: 15px; border-top-right-radius: 15px; border-bottom-right-radius: 15px; border-bottom-left-radius: 15px; height: auto; width: auto; align-items: center; align-self: auto; border-top-width: 0; border-right-width: 0; border-bottom-width: 0; border-left-width: 0;">
        <engine:Label text="Word" name="Word" class="dialogue-text" style="font-size: 40px; height: auto; width: auto; align-items: flex-start; align-self: center; flex-shrink: 1; -unity-text-outline-color: rgba(165, 0, 0, 0); color: rgb(165, 0, 0);" />
        <engine:Label text="No Notes For This Word" name="Notes" class="dialogue-text" style="font-size: 30px; margin-left: 10px; margin-right: 10px; -unity-font-definition: url(&quot;project://database/Assets/Fonts/Harmony.otf?fileID=12800000&amp;guid=e0afdb4613b19e941a9c5e69c3b88d0f&amp;type=3#Harmony&quot;);" />
    </engine:VisualElement>
