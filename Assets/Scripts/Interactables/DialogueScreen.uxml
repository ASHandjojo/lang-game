    <Style src="project://database/Assets/UI/MainMenu/MainMenuStyles.uss?fileID=7433441132597879392&amp;guid=d59d620128eeb9849ac753915a8fa2d4&amp;type=3#MainMenuStyles" />
    <engine:VisualElement name="ScreenContainer" class="dialogue-container">
        <engine:VisualElement name="NotebookBox" class="dialogue-box" style="flex-grow: 1; align-self: auto; display: none;">
            <engine:VisualElement name="Notebook" style="flex-grow: 0; background-color: rgb(255, 224, 152); width: 100%; height: 100%; align-content: auto; position: relative; min-width: 100%; min-height: 100%; border-top-left-radius: 35px; border-top-right-radius: 35px; border-bottom-right-radius: 35px; border-bottom-left-radius: 35px; display: flex;">
                <engine:VisualElement name="NotebookTop" style="flex-grow: 1; flex-direction: row; height: 100%; align-items: center;">
                    <engine:Button text="Journal" name="JournalButton" enable-rich-text="false" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" enabled="true" class="button rebinding" style="align-self: center; left: auto; width: 12%; height: 72px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-bottom: 0; margin-top: 40px; opacity: 1; margin-left: 7%; -unity-background-image-tint-color: rgb(255, 255, 255); font-size: 30px;" />
                    <engine:Button text="Dictionary" name="DictionaryButton" enable-rich-text="true" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" enabled="true" class="button rebinding" style="align-self: center; left: auto; width: 12%; height: 72px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-bottom: 0; margin-top: 40px; opacity: 1; border-left-width: 1px; margin-right: 2%; margin-left: 3%; font-size: 30px; -unity-background-image-tint-color: rgb(255, 251, 251);" />
                    <engine:Label text="NoteBook" name="Title" class="headers" style="font-size: 60px; -unity-text-align: upper-center; top: 0; left: auto; white-space: nowrap; align-self: auto; margin-left: 5.5%;" />
                    <engine:Button text="X" name="BackButton" enable-rich-text="true" emoji-fallback-support="false" double-click-selects-word="false" triple-click-selects-line="false" display-tooltip-when-elided="false" enabled="true" class="button rebinding" style="align-self: center; left: auto; width: 4%; height: 72px; padding-top: 0; padding-right: 0; padding-bottom: 0; padding-left: 0; margin-bottom: 0; margin-top: 40px; opacity: 1; border-left-width: 1px; margin-right: 2%; margin-left: 32%; font-size: 30px; -unity-background-image-tint-color: rgb(255, 251, 251);" />
                </engine:VisualElement>
                <engine:VisualElement name="DictionarySlot1" style="flex-grow: 1; height: 100%; flex-direction: row; width: 100%; background-image: none; -unity-text-align: middle-left; justify-content: center; align-items: center; display: flex;">
                    <engine:Label text="Word" name="Word1" class="hotkey-text TranslatedLabel" style="-unity-text-align: lower-center; height: 40%; width: 50%; font-size: 40px; padding-bottom: 1%; -unity-font-style: bold; color: rgb(165, 0, 0); -unity-font-definition: url(&quot;project://database/Assets/Fonts/Melody.otf?fileID=12800000&amp;guid=ef39abd9056a9d446b1bf89b37383641&amp;type=3#Melody&quot;);" />
                    <engine:TextField placeholder-text="Notes..." name="Notes1" class="headers" style="width: 50%; font-size: 40px; height: 50%; padding-right: 10%; -unity-font-style: normal;" />
